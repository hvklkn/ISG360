generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EXPERT
  COMPANY_USER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum CompanySector {
  MANUFACTURING
  LOGISTICS
  FOOD_PRODUCTION
  CONSTRUCTION
}

enum CompanyStatus {
  HEALTHY
  ATTENTION
  CRITICAL
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(COMPANY_USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Company {
  id           Int           @id @default(autoincrement())
  name         String
  sector       CompanySector @default(MANUFACTURING)
  employeeCount Int          @default(0)
  nextAuditAt  DateTime?
  status       CompanyStatus @default(HEALTHY)
  address      String?
  phone        String?
  email        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employees Employee[]
  risks     Risk[]
  documents Document[]
}

model Employee {
  id         Int        @id @default(autoincrement())
  companyId  Int
  fullName   String
  tcNo       String     @unique
  position   String
  department String
  phone      String
  email      String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents  Document[]
}

model Training {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  validUntil  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Risk {
  id          Int        @id @default(autoincrement())
  companyId   Int
  title       String
  description String
  level       RiskLevel  @default(MEDIUM)
  status      RiskStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Document {
  id         Int       @id @default(autoincrement())
  companyId  Int
  employeeId Int?
  title      String
  fileUrl    String
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}
